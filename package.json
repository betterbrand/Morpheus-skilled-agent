{
  "name": "morpheus-node-manager",
  "version": "1.0.0",
  "description": "CLI + MCP + OpenAI tools for managing Morpheus Lumerin provider nodes",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "morpheus-node-manager": "dist/cli.js",
    "morpheus-node-manager-mcp": "dist/mcp-server.js"
  },
  "files": ["dist/"],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "node --watch dist/cli.js",
    "test": "npm run build && node --test test/core.test.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
